# ============================================================================
# LetA Mem0 — Developer Dev Loop Env (LOCAL TESTING ONLY)
# ============================================================================
# This file is for /Users/<you>/leta/mem0/deploy/ on the developer box.
# Production env lives in mcfo-finsys/agent-memory-server/.env on the server.
# ============================================================================

# Vector store selector (LetA patch)
MEM0_VECTOR_STORE=qdrant

# Qdrant target (resolved via the compose service name)
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_NAME=leta_dev_local_memory_e3small_v1
# QDRANT_API_KEY=            # optional, defense in depth even on docker network

# Auth (dev only)
AUTH_DISABLED=true            # NEVER true in production
ADMIN_API_KEY=                # leave empty when AUTH_DISABLED=true
JWT_SECRET=dev-local-only-replace-in-prod

# App DB (Mem0 server's own request_log / users table)
POSTGRES_HOST=appdb
POSTGRES_PORT=5432
POSTGRES_DB=mem0_app
POSTGRES_USER=mem0
POSTGRES_PASSWORD=mem0-local-dev
POSTGRES_COLLECTION_NAME=memories   # ignored when MEM0_VECTOR_STORE=qdrant

# LLM + embedder (OpenRouter via OpenAI-compatible base URL)
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=                     # set to your OpenRouter key for local testing
MEM0_DEFAULT_LLM_MODEL=openai/gpt-5-mini
MEM0_DEFAULT_EMBEDDER_MODEL=openai/text-embedding-3-small

# Telemetry off for local dev (don't dirty upstream's anonymous metrics)
MEM0_TELEMETRY=false
